#!/usr/bin/env bash
# Zelretch one-command deployment entry point.
#
# This script is what the Dockerfile runs as CMD. It:
#   1. Installs the wizard's Python dependencies (Flask, Motor, Kurigram).
#   2. Launches `python deploy.py`, which opens a local web wizard.
#   3. The wizard collects configuration, then starts the bot itself.
#
# For headless / pre-configured deployments, set every required env var
# in the environment (or .env) and the wizard's "Restore from database"
# flow will let you continue from a previous deployment.
set -euo pipefail

cd "$(dirname "$0")"

echo "=== Zelretch Deployment Wizard ==="
python3 -c "import flask, motor, pyrogram" 2>/dev/null || {
    echo "Installing wizard dependencies..."
    python3 -m pip install --root-user-action=ignore --upgrade pip setuptools wheel
    python3 -m pip install --root-user-action=ignore -r requirements.txt
}

echo "Starting wizard..."
exec python3 deploy.py
