# Reference only — the wizard writes the real .env at deploy time.
# You do NOT need to copy or edit this file to deploy Zelretch.
#
# To deploy:  ./setup    (or  python deploy.py)
# Then open the URL the wizard prints.

API_HASH=your_api_hash
API_ID=your_api_id
BOT_TOKEN=your_bot_token
DATABASE_URL=your_mongodb_url
DATABASE_NAME=Zelretch
LOGGER_ID=your_logger_group_or_channel_id
OWNER_ID=your_telegram_user_id
HANDLERS=. ! ?
PLUGINS_REPO=Siamking672/Zelretch-Plugins
PLUGINS_BRANCH=main
