# ===== AstralBot configuration =====
#
# This file is OPTIONAL — you can generate it via the setup wizard:
#
#     python -m astralbot
#
# The wizard opens a web page at http://localhost:8080 and walks you through
# all required variables. You can also create a userbot session interactively
# in the wizard (or skip it and do it later via the `.session` command).
#
# If you prefer to write this file manually, fill in the values below and
# then run `python -m astralbot --no-wizard`.

# ---- Telegram API credentials [REQUIRED] ----
# Get these from https://my.telegram.org/apps
API_ID=0
API_HASH=your_api_hash_here

# ---- At least ONE of the following is REQUIRED ----
# Option A: Pyrogram StringSession (lets the bot run as your personal account)
# Generate with the setup wizard, or with: python -m astralbot.utils.gen_session
# STRING_SESSION=your_string_session_here

# Option B: BotFather bot token (lets the bot run as a regular bot — limited)
# You can also paste this in the setup wizard if you want to skip session creation.
# BOT_TOKEN=123456:ABC-DEF...

# ---- Optional ----
# MongoDB URI (if unset, AstralBot uses SQLite — zero-config, file-based at userdata/astralbot.db)
# DATABASE_URL=mongodb://localhost:27017
# DATABASE_NAME=astralbot

# Telegram chat ID for WARNING+ log forwarding
# LOG_CHAT_ID=-1001234567890

# Your Telegram user ID (auto-detected from STRING_SESSION if unset)
# OWNER_ID=123456789

# Space-separated list of sudo user IDs
# SUDO_USERS=11111111 22222222

# Command prefixes (space-separated; first is shown in help text)
HANDLERS=. !

# External plugin repository (cloned at startup)
PLUGIN_REPO=AstralBot/AstralModules
PLUGIN_BRANCH=main

# Space-separated plugin names to skip at startup
# DISABLED_PLUGINS=afk purge

# Pyrogram worker count
WORKERS=8
